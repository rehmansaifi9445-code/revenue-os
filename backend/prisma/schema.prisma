generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String      @id @default(cuid())
  fullName       String
  businessName   String
  mobileNumber   String      @unique
  passwordHash   String

  isActive       Boolean     @default(true)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  sessions       Session[]
  business       Business?
  @@map("users")
}

model Session {
  id              String      @id @default(cuid())

  userId          String

  refreshToken    String      @unique

  expiresAt       DateTime

  createdAt       DateTime    @default(now())

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])

  @@map("sessions")
}
model Business {
  id           String   @id @default(cuid())

  ownerId      String   @unique

  name         String
  industry     String?
  gstNumber    String?
  panNumber    String?

  email        String?
  mobileNumber String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  country      String?
  postalCode   String?

  currency     String   @default("INR")
  timezone     String   @default("Asia/Kolkata")

  logoUrl      String?

  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner         User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

 @@index([ownerId])  
 @@map("businesses")
 payments Payment[]
 reminders Reminder[]
}
 model Customer {
  id                String   @id @default(cuid())

  businessId        String

  fullName          String

  companyName       String?

  mobileNumber      String

  alternateNumber   String?

  email             String?

  gstNumber         String?

  panNumber         String?

  addressLine1      String?

  addressLine2      String?

  city              String?

  state             String?

  country           String?

  postalCode        String?

  paymentTerms      Int      @default(0)

  creditLimit       Decimal? @db.Decimal(18,2)

  openingBalance    Decimal  @default(0) @db.Decimal(18,2)

  outstandingAmount Decimal  @default(0) @db.Decimal(18,2)

  totalRevenue      Decimal  @default(0) @db.Decimal(18,2)

  notes             String?

  tags              String?

  isActive          Boolean  @default(true)

  createdAt         DateTime @default(now())

  updatedAt         DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])

  @@index([mobileNumber])

  @@map("customers")
  payments Payment[]
}
  model Invoice {
  id               String   @id @default(cuid())

  businessId       String
  customerId       String

  invoiceNumber    String   @unique

  status           String   @default("DRAFT")

  issueDate        DateTime

  dueDate          DateTime

  subtotal         Decimal  @db.Decimal(18,2)

  taxAmount        Decimal  @default(0) @db.Decimal(18,2)

  discountAmount   Decimal  @default(0) @db.Decimal(18,2)

  totalAmount      Decimal  @db.Decimal(18,2)

  paidAmount       Decimal  @default(0) @db.Decimal(18,2)

  balanceAmount    Decimal  @db.Decimal(18,2)

  notes            String?

  createdAt        DateTime @default(now())

  updatedAt        DateTime @updatedAt

  business Business @relation(
    fields: [businessId],
    references: [id],
    onDelete: Cascade,
    reminders Reminder[]
 )

  customer Customer @relation(
    fields: [customerId],
    references: [id],
    onDelete: Cascade,
  )

  items InvoiceItem[]
  
  @@index([businessId])

  @@index([customerId])

  @@index([status])

  @@map("invoices")
  payments Payment[]
}
  model InvoiceItem {
  id            String   @id @default(cuid())

  invoiceId     String

  itemName      String

  description   String?

  quantity      Decimal @db.Decimal(18,2)

  unitPrice     Decimal @db.Decimal(18,2)

  taxPercent    Decimal @default(0) @db.Decimal(5,2)

  discount      Decimal @default(0) @db.Decimal(18,2)

  total         Decimal @db.Decimal(18,2)

  createdAt     DateTime @default(now())

  invoice Invoice @relation(
    fields: [invoiceId],
    references: [id],
    onDelete: Cascade,
  )

  @@index([invoiceId])

  @@map("invoice_items")
  payments Payment[]
}

 model Payment {
  id              String   @id @default(cuid())

  businessId      String
  customerId      String
  invoiceId       String

  paymentNumber   String   @unique

  amount          Decimal  @db.Decimal(18,2)

  paymentDate     DateTime

  paymentMethod   String

  referenceNumber String?

  notes           String?

  status          String   @default("COMPLETED")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business @relation(
    fields: [businessId],
    references: [id],
    onDelete: Cascade,
  )

  customer Customer @relation(
    fields: [customerId],
    references: [id],
    onDelete: Cascade,
  )

  invoice Invoice @relation(
    fields: [invoiceId],
    references: [id],
    onDelete: Cascade,
  )

  @@index([businessId])
  @@index([customerId])
  @@index([invoiceId])
  @@index([status])

  @@map("payments")
}
 model Reminder {
  id            String   @id @default(cuid())

  businessId    String
  invoiceId     String

  type          String
  channel       String

  status        String   @default("PENDING")

  scheduledAt   DateTime
  sentAt        DateTime?

  subject       String?
  message       String?

  retryCount    Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business Business @relation(
    fields: [businessId],
    references: [id],
    onDelete: Cascade,
  )

  invoice Invoice @relation(
    fields: [invoiceId],
    references: [id],
    onDelete: Cascade,
  )

  @@index([businessId])
  @@index([invoiceId])
  @@index([status])

  @@map("reminders")
}
