# ===========================================
# RevenueFlow Backend Environment
# ===========================================

# Application
NODE_ENV=development
PORT=3000
APP_NAME=RevenueFlow
APP_URL=http://localhost:3000

# ===========================================
# Database
# ===========================================

DATABASE_URL="postgresql://username:password@localhost:5432/revenueflow"

# ===========================================
# JWT Authentication
# ===========================================

JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=1d

JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# ===========================================
# Redis
# ===========================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# Razorpay
# ===========================================

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ===========================================
# Stripe
# ===========================================

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ===========================================
# OpenAI
# ===========================================

OPENAI_API_KEY=

# ===========================================
# Email
# ===========================================

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ===========================================
# WhatsApp
# ===========================================

WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# ===========================================
# Logging
# ===========================================

LOG_LEVEL=info
